# PostgreSQL
POSTGRES_DB=financa
POSTGRES_USER=financa
POSTGRES_PASSWORD=change_me_strong_password_here

# API authentication (static Bearer token for personal use)
API_TOKEN=change_me_long_random_token_here

# Telegram bot
TELEGRAM_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_ALLOWED_CHAT_ID=123456789
# Full public HTTPS base URL (without trailing slash)
TELEGRAM_WEBHOOK_URL=https://goblinfinance.duckdns.org
# Random secret — generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=change_me_random_hex_secret

# OpenClaw integration (optional, leave blank to disable)
OPENCLAW_API_URL=
OPENCLAW_API_KEY=

# Backblaze B2 remote backup (optional but strongly recommended)
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
# rclone remote name configured in /root/.config/rclone/rclone.conf
RCLONE_REMOTE=b2financa

# Traefik / HTTPS
# Domínio apontando para o IP da VPS (ex: financa.seusite.com)
DOMAIN=goblinfinance.duckdns.org
# Nome da rede Docker interna do Traefik (verifique com: docker network ls)
TRAEFIK_NETWORK=traefik-proxy

# Environment
ENVIRONMENT=production
